# Vercel(또는 로컬)에 아래 값을 넣으세요. 인증서 파일 내용 전체를 복사합니다.
# scripts/push-mtls-to-vercel.mjs 로 자동 등록할 수도 있습니다.

TOSS_MTLS_CERT_PEM=
TOSS_MTLS_KEY_PEM=

